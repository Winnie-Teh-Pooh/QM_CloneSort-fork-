{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830401
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Local",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-File",
				"${workspaceFolder}/scripts/build_local.ps1"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": "$msCompile"
		},
		{
			"label": "Build Steam",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-File",
				"${workspaceFolder}/scripts/build_steam.ps1"
			],
			"group": "build",
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": "$msCompile"
		},
		{
			"label": "Launch Quasimorph",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Start-Process 'steam://rungameid/2059170'"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "never",
				"panel": "shared",
				"showReuseMessage": false,
				"clear": false
			}
		},
		{
			"label": "Build and Run",
			"dependsOn": [
				"Build Steam",
				"Launch Quasimorph"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "Format Steam README",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-File",
				"${workspaceFolder}/scripts/markdown_to_steam.ps1"
			],
			"group": "none",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Create Project",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-File",
				"${workspaceFolder}/scripts/create_project.ps1",
				"-NewName",
				"${input:newName}"
			],
			"group": "none",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "newName",
			"type": "promptString",
			"description": "New mod name (e.g. QM_Freezer)"
		}
	]
}
